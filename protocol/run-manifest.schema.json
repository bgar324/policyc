{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policyc.dev/schema/run-manifest-1.0.0.json",
  "title": "PolicyC experiment run manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "experimentName", "candidates", "fullPolicyCandidateId", "provider", "model", "modelParameters", "sampleCount", "maxConcurrency", "timeoutSeconds", "retryPolicy", "rateLimit", "evaluator", "outputDirectory", "rawResponseRetention"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "runId": { "type": "string" },
    "experimentName": { "type": "string" },
    "candidates": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "fullPolicyCandidateId": { "type": "string" },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "modelParameters": { "type": "object" },
    "sampleCount": { "type": "integer", "minimum": 1 },
    "maxConcurrency": { "type": "integer", "minimum": 1 },
    "timeoutSeconds": { "type": "number", "exclusiveMinimum": 0 },
    "retryPolicy": { "type": "object" },
    "rateLimit": { "type": "object" },
    "evaluator": { "type": "object" },
    "seed": { "type": ["integer", "null"] },
    "outputDirectory": { "type": "string" },
    "rawResponseRetention": { "enum": ["none", "text", "full"] }
  }
}
